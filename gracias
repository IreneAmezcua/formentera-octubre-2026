  <style>
    :root{
      --bg:#eef6ff;
      --card:#ffffff;
      --text:#0d172a;
      --muted:#526174;
      --accent:#006dff;
      --accent-dark:#0047c7;
      --line:#c9ddf5;
      --shadow:0 20px 40px rgba(0,62,142,0.10);
    }

    *{
      box-sizing:border-box;
      margin:0;
      padding:0;
    }

    body{
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      background:var(--bg);
      color:var(--text);
      display:flex;
      align-items:center;
      justify-content:center;
      min-height:100vh;
      padding:24px;
    }

    .card{
      background:var(--card);
      padding:40px;
      border-radius:20px;
      box-shadow:var(--shadow);
      max-width:600px;
      width:100%;
      text-align:center;
    }

    .eyebrow{
      font-size:14px;
      color:var(--muted);
      margin-bottom:12px;
    }

    h1{
      font-size:36px;
      margin-bottom:16px;
      line-height:1.2;
    }

    .lead{
      font-size:18px;
      margin-bottom:12px;
    }

    .sublead{
      color:var(--muted);
      margin-bottom:28px;
    }

    .actions{
      display:flex;
      gap:12px;
      flex-direction:column;
      margin-bottom:32px;
    }

    .btn{
      display:inline-block;
      padding:14px 20px;
      border-radius:999px;
      text-decoration:none;
      font-weight:600;
      transition:all .2s ease;
    }

    .btn-primary{
      background:var(--accent);
      color:white;
    }

    .btn-primary:hover{
      background:var(--accent-dark);
    }

    .btn-secondary{
      border:1px solid var(--line);
      color:var(--text);
    }

    .box{
      border-top:1px solid var(--line);
      padding-top:24px;
      margin-top:16px;
    }

    .box h2{
      font-size:20px;
      margin-bottom:10px;
    }

    .box p{
      color:var(--muted);
      margin-bottom:6px;
    }

    .brand{
      margin-top:28px;
      font-size:14px;
      color:var(--muted);
    }

    @media (min-width:600px){
      .actions{
        flex-direction:row;
        justify-content:center;
      }
    }
